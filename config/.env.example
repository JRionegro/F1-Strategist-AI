# Example environment configuration
# Copy this file to .env and fill in your values

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here  # For Claude 3.5 Sonnet
GOOGLE_API_KEY=your_google_api_key_here  # For Gemini 2.0 Flash Thinking
LANGSMITH_API_KEY=your_langsmith_api_key_here  # Optional, monitoring

# Data Paths
F1_DATA_PATH=./data/races
TELEMETRY_PATH=./data/telemetry
CACHE_DIR=./cache

# Database
DATABASE_URL=sqlite:///./f1_strategist.db
VECTOR_DB_PATH=./chroma_data

# Application Settings
LOG_LEVEL=INFO
DEBUG_MODE=False
API_PORT=8000
API_HOST=0.0.0.0

# FastF1 Configuration
FASTF1_CACHE_ENABLED=True
FASTF1_CACHE_DIR=./cache/fastf1

# MCP Server Configuration
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8001

# Visualization
DASHBOARD_PORT=8050
STREAMLIT_SERVER_PORT=8501

# Agent Configuration
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT=30

# LLM Configuration
LLM_PROVIDER=hybrid  # hybrid, claude, or gemini
GEMINI_MODEL=gemini-2.0-flash-thinking-exp-1219
COMPLEXITY_THRESHOLD_SIMPLE=0.4
COMPLEXITY_THRESHOLD_COMPLEX=0.7

# Vector Store Configuration
VECTOR_STORE_PROVIDER=chromadb  # chromadb or pinecone
PINECONE_API_KEY=your_pinecone_api_key_here  # Optional, for production
PINECONE_ENVIRONMENT=us-west1-gcp  # Optional
PINECONE_INDEX=f1-strategist

# RAG Configuration
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
VECTOR_DB_COLLECTION=f1_races
MAX_CONTEXT_LENGTH=4000
USE_REDIS=false  # MVP uses Parquet cache only

# LangSmith Monitoring
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=f1-strategist-ai
LOCAL_TOKEN_TRACKING=true  # Fallback when LangSmith unavailable

# Weather API (optional)
WEATHER_API_KEY=your_weather_api_key_here
WEATHER_API_PROVIDER=openweathermap
